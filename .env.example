# ───────────────────── LLM (via OpenRouter) ─────────────────────
# All LLM calls go through OpenRouter's OpenAI-compatible Chat
# Completions API. Default model is a Claude variant; switch
# providers by changing OPENROUTER_MODEL alone — no code changes.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-opus-4.6-fast
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ──────────────── Microsoft 365 ────────────────
# From your Azure AD app registration
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=

# ───────────── Trigger / scanner knobs ─────────
STALE_RA_DAYS=10
POST_MEETING_LOOKBACK_HOURS=6
RA_DOMAIN_ALLOWLIST=acmewealth.com,buildright-insurance.com,cepa-advisors.com

# ──────────────── Beam.ai / Medallia ────────────
# Sentiment analysis is performed by Medallia Text Analytics
# accessed via the Beam.ai Medallia integration:
# https://beam.ai/integrations/medallia/
BEAM_API_KEY=
MEDALLIA_TENANT=
MEDALLIA_PROGRAM_ID=
MEDALLIA_AUTH_TOKEN=
SENTIMENT_TIMEOUT_S=20
SENTIMENT_POLL_INTERVAL_S=2
MEDALLIA_DELETE_AFTER_SCORE=true
