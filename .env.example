# ───────────────────── LLM (local Ollama) ─────────────────────
# Run `ollama serve` locally and make sure this model exists:
#   ollama pull qwen3:1.7b
#   ollama pull deepseek-r1:1.5b
OLLAMA_MODEL=qwen3:1.7b
SENTIMENT_OLLAMA_MODEL=deepseek-r1:1.5b
OLLAMA_BASE_URL=http://localhost:11434/v1

# ──────────────── Microsoft 365 ────────────────
# From your Azure AD app registration
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=

# ───────────── Trigger / scanner knobs ─────────
STALE_RA_DAYS=10
POST_MEETING_LOOKBACK_HOURS=6
RA_DOMAIN_ALLOWLIST=acmewealth.com,buildright-insurance.com,cepa-advisors.com

# ──────────────── Beam.ai / Medallia ────────────
# Sentiment analysis is performed by Medallia Text Analytics
# accessed via the Beam.ai Medallia integration:
# https://beam.ai/integrations/medallia/
BEAM_API_KEY=
MEDALLIA_TENANT=
MEDALLIA_PROGRAM_ID=
MEDALLIA_AUTH_TOKEN=
SENTIMENT_TIMEOUT_S=20
SENTIMENT_POLL_INTERVAL_S=2
MEDALLIA_DELETE_AFTER_SCORE=true
